# Copy this file to .streamlit/secrets.toml and fill in your keys.
# secrets.toml is gitignored — never commit your actual keys.

# Primary LLM: Google Gemini (free tier via Google AI Studio)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "your_gemini_key_here"

# Fallback LLM: Groq (free API, no credit card, fast Llama 3.3 70B)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY = "your_groq_key_here"
